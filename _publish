#!/bin/bash
set -euo pipefail

HTML_OUT=index.html
PDF_OUT=resume.pdf

if command -v pandoc >/dev/null 2>&1; then
  pandoc resume.md -o "$HTML_OUT" -t html5 \
    -f markdown+smart \
    --standalone \
    --email-obfuscation=references \
    --data-dir=_pandoc \
    --include-in-header=_pandoc/header_styles.html \
    --include-before-body=_pandoc/header.html \
    --include-after-body=_pandoc/footer.html \
    --variable="pagetitle:Resume :: Jack Senechal"
else
  if ! command -v md2html >/dev/null 2>&1; then
    echo "error: neither pandoc nor md2html is installed" >&2
    exit 1
  fi

  tmp_body=$(mktemp)
  md2html --github --fhard-soft-breaks resume.md -o "$tmp_body"

  python - "$tmp_body" <<'PY'
from pathlib import Path
import sys

body = Path(sys.argv[1]).read_text()
styles = Path("_pandoc/header_styles.html").read_text()
header = Path("_pandoc/header.html").read_text()
footer = Path("_pandoc/footer.html").read_text()

html = f"""<!DOCTYPE html>
<html lang=\"en\">
  <head>
    <meta charset=\"utf-8\"/>
    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">
    <title>Resume :: Jack Senechal</title>
    {styles}
  </head>
  <body>
    {header}
    {body}
    {footer}
  </body>
</html>
"""

Path("index.html").write_text(html)
PY

  rm -f "$tmp_body"
fi

browser=""
for candidate in google-chrome-stable chromium chromium-browser; do
  if command -v "$candidate" >/dev/null 2>&1; then
    browser="$candidate"
    break
  fi
done

if [[ -z "$browser" ]]; then
  echo "warning: no supported browser found; skipping PDF generation" >&2
  exit 0
fi

"$browser" \
  --headless \
  --disable-gpu \
  --no-sandbox \
  --no-pdf-header-footer \
  --print-to-pdf="$PDF_OUT" \
  "file://$PWD/$HTML_OUT"
